{
  "id": "ion-core-payment-v1",
  "version": "1.0.0",
  "domain": "ion-core",
  "name": "ION Payment Extension (v1)",
  "description": "Indonesian payment method objects — QRIS, VA, EWallet, COD, BIFast, BNPL, Card.",
  "packSchema": "./schema.json",
  "jsonldContext": "./context.jsonld",
  "attachmentPoints": {
    "settlementAttributes": [
      "PaymentDeclaration"
    ]
  },
  "regulatory": [
    "PBI 21/18/PBI/2019",
    "SNAP BI specification",
    "PBI 23/2021"
  ],
  "type": "AttributePack",
  "indexing": {
    "indexable": [
      {
        "path": "$.method"
      },
      {
        "path": "$.collectedBy"
      },
      {
        "path": "$.status"
      }
    ],
    "filterable": [
      {
        "path": "$.method"
      },
      {
        "path": "$.collectedBy"
      }
    ],
    "sortable": []
  },
  "minimalForDiscovery": [
    "method",
    "collectedBy"
  ]
}
