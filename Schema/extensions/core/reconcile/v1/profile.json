{
  "id": "ion-core-reconcile-v1",
  "version": "1.0.0",
  "domain": "ion-core",
  "name": "ION Reconcile Extension (v1)",
  "description": "Inter-NP financial reconciliation — amounts, adjustments, withholding, settlement.",
  "packSchema": "./schema.json",
  "jsonldContext": "./context.jsonld",
  "attachmentPoints": {
    "settlementAttributes": [
      "IONReconciliation"
    ]
  },
  "apis": [
    "reconcile",
    "on_reconcile"
  ],
  "type": "AttributePack",
  "indexing": {
    "indexable": [
      {
        "path": "$.reconId"
      },
      {
        "path": "$.contractId"
      },
      {
        "path": "$.reconStatus"
      }
    ],
    "filterable": [
      {
        "path": "$.reconId"
      },
      {
        "path": "$.contractId"
      }
    ],
    "sortable": []
  },
  "minimalForDiscovery": [
    "reconId",
    "contractId"
  ]
}