{
  "id": "ion-core-rating-v1",
  "version": "1.0.0",
  "domain": "ion-core",
  "name": "ION Rating Extension (v1)",
  "description": "Post-transaction rating — provider, item, fulfilment, agent. Scale 1-5.",
  "packSchema": "./schema.json",
  "jsonldContext": "./context.jsonld",
  "attachmentPoints": {
    "ratingAttributes": [
      "IONRating"
    ]
  },
  "apis": [
    "rate",
    "on_rate"
  ],
  "type": "AttributePack",
  "indexing": {
    "indexable": [
      {
        "path": "$.ratingCategory"
      },
      {
        "path": "$.ratingValue"
      }
    ],
    "filterable": [
      {
        "path": "$.ratingCategory"
      },
      {
        "path": "$.ratingValue"
      }
    ],
    "sortable": []
  },
  "minimalForDiscovery": [
    "ratingCategory",
    "ratingValue"
  ]
}