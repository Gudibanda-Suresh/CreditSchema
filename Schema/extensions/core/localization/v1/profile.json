{
  "id": "ion-core-localization-v1",
  "version": "1.0.0",
  "domain": "ion-core",
  "name": "ION Localization Extension (v1)",
  "description": "Multilingual text objects for catalog content. Bahasa Indonesia always required.",
  "packSchema": "./schema.json",
  "jsonldContext": "./context.jsonld",
  "attachmentPoints": {
    "resourceAttributes": [
      "IONCatalogLocalization"
    ],
    "providerAttributes": [
      "IONCatalogLocalization"
    ]
  },
  "regulatory": [
    "ION Network Policy — bilingual catalog requirement"
  ],
  "type": "AttributePack",
  "indexing": {
    "indexable": [
      {
        "path": "$.name"
      },
      {
        "path": "$.shortDesc"
      }
    ],
    "filterable": [
      {
        "path": "$.name"
      },
      {
        "path": "$.shortDesc"
      }
    ],
    "sortable": []
  },
  "minimalForDiscovery": [
    "name"
  ]
}
