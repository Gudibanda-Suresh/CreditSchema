{
  "id": "ion-core-support-v1",
  "version": "1.0.0",
  "domain": "ion-core",
  "name": "ION Support Extension (v1)",
  "description": "Consumer complaint ticket. Buyer raises order issues to seller. IGM-derived.",
  "packSchema": "./schema.json",
  "jsonldContext": "./context.jsonld",
  "attachmentPoints": {
    "supportAttributes": [
      "IONSupportTicket"
    ]
  },
  "apis": [
    "support",
    "on_support"
  ],
  "type": "AttributePack",
  "indexing": {
    "indexable": [
      {
        "path": "$.id"
      },
      {
        "path": "$.category"
      },
      {
        "path": "$.status"
      }
    ],
    "filterable": [
      {
        "path": "$.id"
      },
      {
        "path": "$.category"
      }
    ],
    "sortable": []
  },
  "minimalForDiscovery": [
    "category"
  ]
}
