{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.ion.id/hospitality/delivery/v1",
  "title": "RestaurantMenuItem",
  "description": "Resource attributes for prepared F&B items (HSC-restaurant-ordering). Hospitality sector, food delivery and self-pickup.",
  "type": "object",
  "required": [
    "quantity",
    "resourceStructure",
    "resourceTangibility",
    "images",
    "availability",
    "countryOfOrigin",
    "ageRestricted",
    "preparationTime"
  ],
  "additionalProperties": true,
  "properties": {
    "quantity": {
      "type": "object",
      "required": [
        "value",
        "unit"
      ],
      "properties": {
        "value": {
          "type": "number"
        },
        "unit": {
          "type": "string",
          "enum": [
            "portion",
            "piece",
            "cup",
            "bowl",
            "plate",
            "set",
            "litre",
            "millilitre"
          ]
        }
      }
    },
    "resourceStructure": {
      "type": "string",
      "enum": [
        "PLAIN",
        "WITH_EXTRAS",
        "COMPOSED",
        "BUNDLE"
      ]
    },
    "resourceTangibility": {
      "type": "string",
      "const": "PHYSICAL"
    },
    "logisticsServiceType": {
      "type": "string",
      "enum": [
        "HYPERLOCAL",
        "DOMESTIC_SURFACE"
      ]
    },
    "ageRestricted": {
      "type": "boolean"
    },
    "countryOfOrigin": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      },
      "minItems": 1
    },
    "availability": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "IN_STOCK",
            "OUT_OF_STOCK",
            "PREORDER"
          ]
        },
        "maxOrderQty": {
          "type": "integer"
        },
        "nextAvailableAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "preparationTime": {
      "type": "string",
      "description": "ISO 8601 duration e.g. PT20M"
    },
    "menuCategory": {
      "type": "object"
    },
    "customisationGroups": {
      "type": "array"
    },
    "identity": {
      "type": "object"
    },
    "itemRating": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "classification": {
      "type": "string",
      "enum": [
        "HALAL",
        "NON_HALAL",
        "VEG",
        "NON_VEG",
        "HALAL_PENDING",
        "NOT_APPLICABLE"
      ]
    },
    "halalCertNumber": {
      "type": "string"
    },
    "allergens": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cuisineType": {
      "type": "string"
    },
    "spiceLevel": {
      "type": "string",
      "enum": [
        "NONE",
        "LOW",
        "MEDIUM",
        "HIGH",
        "EXTRA_HOT"
      ]
    },
    "isAlcoholic": {
      "type": "boolean"
    },
    "bpomRegistration": {
      "type": "string"
    },
    "nutritionalInfo": {
      "type": "string"
    }
  }
}