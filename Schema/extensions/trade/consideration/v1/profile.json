{
  "id": "ion-trade-consideration-v1",
  "version": "1.0.0",
  "domain": "trade",
  "name": "ION Trade Consideration Extension (v1)",
  "description": "Price breakup line types, PPN/PPnBM tax rates, discount mechanics.",
  "packSchema": "./schema.json",
  "jsonldContext": "./context.jsonld",
  "attachmentPoints": {
    "considerationAttributes": [
      "TradeConsideration"
    ]
  },
  "extends": "beckn:Consideration",
  "type": "AttributePack",
  "indexing": {
    "indexable": [
      {
        "path": "$.breakupLineType"
      },
      {
        "path": "$.totalAmount"
      }
    ],
    "filterable": [
      {
        "path": "$.breakupLineType"
      },
      {
        "path": "$.totalAmount"
      }
    ],
    "sortable": []
  },
  "minimalForDiscovery": [
    "breakupLineType",
    "totalAmount",
    "currency"
  ]
}