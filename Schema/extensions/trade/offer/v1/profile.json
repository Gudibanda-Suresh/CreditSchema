{
  "id": "ion-trade-offer-v1",
  "version": "1.0.0",
  "domain": "trade",
  "name": "ION Trade Offer Extension (v1)",
  "description": "Terms of sale — cancel, return, warranty, COD, promotions, consumer care.",
  "packSchema": "./schema.json",
  "jsonldContext": "./context.jsonld",
  "attachmentPoints": {
    "offerAttributes": [
      "TradeOffer"
    ]
  },
  "extends": "beckn:Offer",
  "type": "AttributePack",
  "indexing": {
    "indexable": [
      {
        "path": "$.cancellationPolicy"
      },
      {
        "path": "$.returnPolicy"
      }
    ],
    "filterable": [
      {
        "path": "$.cancellationPolicy"
      },
      {
        "path": "$.returnPolicy"
      }
    ],
    "sortable": []
  },
  "minimalForDiscovery": [
    "cancellationPolicy",
    "returnable",
    "returnPolicy"
  ]
}