{
  "@context": {
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "schema": "https://schema.org/",
    "ion": "https://schema.ion.id/finance/offer/v1#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#"
  },
  "@graph": [
    {
      "@id": "ion:CreditApproval",
      "@type": "rdfs:Class",
      "rdfs:subClassOf": {
        "@id": "schema:LoanOrCredit"
      },
      "rdfs:label": "CreditApproval",
      "rdfs:comment": "Per-applicant credit offer with exact approved values. Placed in Beckn Offer.offerAttributes within Contract.commitments[].offer returned in on_select. Offer.validity.endDate mirrors domain validUntil; offerStatus carries the OJK credit decision (separate from Beckn Commitment.status)."
    },
    {
      "@id": "ion:EffectiveRate",
      "@type": "rdfs:Class",
      "rdfs:label": "EffectiveRate",
      "rdfs:comment": "Exact rate/method/yieldType for this specific offer. Frozen in LoanAgreement if accepted.",
      "rdfs:subClassOf": {
        "@id": "schema:LoanOrCredit"
      }
    },
    {
      "@id": "ion:MonthlyInstallment",
      "@type": "rdfs:Class",
      "rdfs:label": "MonthlyInstallment",
      "rdfs:comment": "First installment breakdown (total, principal, interest). Full schedule in LoanAgreement after confirm.",
      "rdfs:subClassOf": {
        "@id": "schema:RepaymentSpecification"
      }
    },
    {
      "@id": "ion:TotalFees",
      "@type": "rdfs:Class",
      "rdfs:label": "TotalFees",
      "rdfs:comment": "All upfront fees and APR-equivalent mandatory per POJK 6/2022 RIPLAY disclosure.",
      "rdfs:subClassOf": {
        "@id": "schema:PriceSpecification"
      }
    },
    {
      "@id": "ion:DisbursementSchedule",
      "@type": "rdfs:Class",
      "rdfs:label": "DisbursementSchedule",
      "rdfs:comment": "Expected disbursement timeline and method once all conditions are met.",
      "rdfs:subClassOf": {
        "@id": "schema:DeliveryTimeSettings"
      }
    },
    {
      "@id": "ion:InternalCreditScore",
      "@type": "rdfs:Class",
      "rdfs:label": "InternalCreditScore",
      "rdfs:comment": "Lender's proprietary credit assessment result for this borrower.",
      "rdfs:subClassOf": {
        "@id": "schema:Rating"
      }
    },
    {
      "@id": "ion:offerReference",
      "@type": "rdf:Property",
      "rdfs:label": "offerReference",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "Unique offer reference ID generated by the lender. Correlates on_select offer with lender's internal credit application."
    },
    {
      "@id": "ion:validUntil",
      "@type": "rdf:Property",
      "rdfs:label": "validUntil",
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "rdfs:comment": "Offer expiry timestamp in ISO 8601 with WIB offset (+07:00). After this, offer must not be accepted."
    },
    {
      "@id": "ion:offerStatus",
      "@type": "rdf:Property",
      "rdfs:label": "offerStatus",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "OJK credit decision: UNDER_EVALUATION, APPROVED, CONDITIONALLY_APPROVED, REJECTED, or EXPIRED."
    },
    {
      "@id": "ion:approvedPrincipal",
      "@type": "rdf:Property",
      "rdfs:label": "approvedPrincipal",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Exact approved principal amount (plafond) for this borrower in IDR."
    },
    {
      "@id": "ion:approvedTenor",
      "@type": "rdf:Property",
      "rdfs:label": "approvedTenor",
      "rdfs:range": {
        "@id": "xsd:integer"
      },
      "rdfs:comment": "Exact approved tenure (value + unit) within the product template's min/max range."
    },
    {
      "@id": "ion:effectiveRate",
      "@type": "rdf:Property",
      "rdfs:label": "effectiveRate",
      "rdfs:range": {
        "@id": "ion:EffectiveRate"
      },
      "rdfs:comment": "Exact annual interest/margin rate, calculation method, and yield type offered to this borrower."
    },
    {
      "@id": "ion:monthlyInstallment",
      "@type": "rdf:Property",
      "rdfs:label": "monthlyInstallment",
      "rdfs:range": {
        "@id": "ion:MonthlyInstallment"
      },
      "rdfs:comment": "Monthly installment breakdown. For ANNUITY: first installment only; full schedule in LoanAgreement."
    },
    {
      "@id": "ion:totalFees",
      "@type": "rdf:Property",
      "rdfs:label": "totalFees",
      "rdfs:range": {
        "@id": "ion:TotalFees"
      },
      "rdfs:comment": "Complete fee breakdown including APR equivalent for RIPLAY disclosure per POJK 6/2022."
    },
    {
      "@id": "ion:additionalConditions",
      "@type": "rdf:Property",
      "rdfs:label": "additionalConditions",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "Outstanding conditions for CONDITIONALLY_APPROVED, or rejection reason for REJECTED (SPPP letter required per POJK 6/2022)."
    },
    {
      "@id": "ion:disbursementSchedule",
      "@type": "rdf:Property",
      "rdfs:label": "disbursementSchedule",
      "rdfs:range": {
        "@id": "ion:DisbursementSchedule"
      },
      "rdfs:comment": "Expected disbursement timeline and method after document completion."
    },
    {
      "@id": "ion:internalCreditScore",
      "@type": "rdf:Property",
      "rdfs:label": "internalCreditScore",
      "rdfs:range": {
        "@id": "ion:InternalCreditScore"
      },
      "rdfs:comment": "Lender's internal credit risk assessment result for this borrower."
    },
    {
      "@id": "ion:percentPerYear",
      "@type": "rdf:Property",
      "rdfs:label": "percentPerYear",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Annual rate in percent (% per tahun). Frozen in LoanAgreement if offer accepted."
    },
    {
      "@id": "ion:method",
      "@type": "rdf:Property",
      "rdfs:label": "method",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "Installment calculation method: ANNUITY, FLAT, or EFFECTIVE."
    },
    {
      "@id": "ion:yieldType",
      "@type": "rdf:Property",
      "rdfs:label": "yieldType",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "Cost-of-fund mechanism: FIXED, FLOATING, COMBINED, MARGIN, or NISBAH."
    },
    {
      "@id": "ion:fixedPeriodYears",
      "@type": "rdf:Property",
      "rdfs:label": "fixedPeriodYears",
      "rdfs:range": {
        "@id": "xsd:integer"
      },
      "rdfs:comment": "Fixed-rate period in years for COMBINED products before floating rate applies."
    },
    {
      "@id": "ion:floatingRateAfterFixedPercent",
      "@type": "rdf:Property",
      "rdfs:label": "floatingRateAfterFixedPercent",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Floating rate applicable after fixed period ends (COMBINED products only)."
    },
    {
      "@id": "ion:totalIDR",
      "@type": "rdf:Property",
      "rdfs:label": "totalIDR",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Total monthly installment in IDR (auto-debit angsuran amount)."
    },
    {
      "@id": "ion:principalIDR",
      "@type": "rdf:Property",
      "rdfs:label": "principalIDR",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Principal repayment component. Increases each month for ANNUITY; constant for FLAT."
    },
    {
      "@id": "ion:interestIDR",
      "@type": "rdf:Property",
      "rdfs:label": "interestIDR",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Interest/margin component. Decreases each month for ANNUITY; constant for FLAT."
    },
    {
      "@id": "ion:provisionFeeIDR",
      "@type": "rdf:Property",
      "rdfs:label": "provisionFeeIDR",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Provision/origination fee in IDR. IDR 0 for KUR and FLPP per government regulation."
    },
    {
      "@id": "ion:administrationFeeIDR",
      "@type": "rdf:Property",
      "rdfs:label": "administrationFeeIDR",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Administration processing fee in IDR. IDR 0 for government programs (KUR, FLPP)."
    },
    {
      "@id": "ion:appraisalFeeIDR",
      "@type": "rdf:Property",
      "rdfs:label": "appraisalFeeIDR",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "KJPP collateral appraisal fee in IDR. Required for KPR, KKB, and secured business credit."
    },
    {
      "@id": "ion:notaryFeeIDR",
      "@type": "rdf:Property",
      "rdfs:label": "notaryFeeIDR",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Estimated notary/PPAT fee in IDR for deed preparation. IDR 0 for unsecured small products."
    },
    {
      "@id": "ion:lifeInsurancePremiumIDR",
      "@type": "rdf:Property",
      "rdfs:label": "lifeInsurancePremiumIDR",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Life insurance single premium paid upfront at akad for full tenure (IDR)."
    },
    {
      "@id": "ion:annualFireInsuranceIDR",
      "@type": "rdf:Property",
      "rdfs:label": "annualFireInsuranceIDR",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Annual fire insurance premium in IDR. Mandatory for KPR per BI PBI 12/2010."
    },
    {
      "@id": "ion:stampDutyIDR",
      "@type": "rdf:Property",
      "rdfs:label": "stampDutyIDR",
      "rdfs:range": {
        "@id": "xsd:integer"
      },
      "rdfs:comment": "Stamp duty per document (IDR 10,000 per UU No. 10/2020). e-Meterai may be used."
    },
    {
      "@id": "ion:totalUpfrontCostsIDR",
      "@type": "rdf:Property",
      "rdfs:label": "totalUpfrontCostsIDR",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Total upfront costs paid at akad signing in IDR. Disclosed in RIPLAY per POJK 6/2022."
    },
    {
      "@id": "ion:aprEquivalent",
      "@type": "rdf:Property",
      "rdfs:label": "aprEquivalent",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "All-in annualised cost of credit % including all mandatory fees. Mandatory RIPLAY disclosure per POJK 6/POJK.07/2022."
    },
    {
      "@id": "ion:targetBusinessDays",
      "@type": "rdf:Property",
      "rdfs:label": "targetBusinessDays",
      "rdfs:range": {
        "@id": "xsd:integer"
      },
      "rdfs:comment": "Target business days from complete document submission to fund disbursement."
    },
    {
      "@id": "ion:disbursementMethod",
      "@type": "rdf:Property",
      "rdfs:label": "disbursementMethod",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "Disbursement method: BANK_TRANSFER, DEVELOPER_TRANSFER, DEALER_TRANSFER, CASH, VIRTUAL_ACCOUNT."
    },
    {
      "@id": "ion:score",
      "@type": "rdf:Property",
      "rdfs:label": "score",
      "rdfs:range": {
        "@id": "xsd:integer"
      },
      "rdfs:comment": "Lender's proprietary internal credit score on their scale (e.g. 300–850)."
    },
    {
      "@id": "ion:category",
      "@type": "rdf:Property",
      "rdfs:label": "category",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "Qualitative risk category: EXCELLENT, GOOD, FAIR, or POOR."
    },
    {
      "@id": "ion:slikGrade",
      "@type": "rdf:Property",
      "rdfs:label": "slikGrade",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "OJK SLIK/iDEB collectibility grade: '1' = Lancar (Current), '2' = Special Mention."
    },
    {
      "@id": "ion:YieldType",
      "@type": [
        "rdfs:Class",
        "skos:ConceptScheme"
      ],
      "rdfs:label": "YieldType",
      "rdfs:comment": "Taxonomy of cost-of-fund mechanisms. Canonical definition in finance/resource/v1. owl:sameAs declared here for cross-pack resolution.",
      "owl:sameAs": {
        "@id": "https://schema.ion.id/finance/resource/v1#YieldType"
      }
    },
    {
      "@id": "ion:CalculationMethod",
      "@type": [
        "rdfs:Class",
        "skos:ConceptScheme"
      ],
      "rdfs:label": "CalculationMethod",
      "rdfs:comment": "Taxonomy of amortisation calculation methods. Canonical definition in finance/resource/v1. owl:sameAs declared here for cross-pack resolution.",
      "owl:sameAs": {
        "@id": "https://schema.ion.id/finance/resource/v1#CalculationMethod"
      }
    },
    {
      "@id": "ion:OfferStatus",
      "@type": [
        "rdfs:Class",
        "skos:ConceptScheme"
      ],
      "rdfs:label": "OfferStatus",
      "rdfs:comment": "Taxonomy of credit offer decision states."
    },
    {
      "@id": "ion:APPROVED",
      "@type": "skos:Concept",
      "skos:prefLabel": "APPROVED",
      "skos:broader": {
        "@id": "ion:OfferStatus"
      },
      "rdfs:comment": "All credit conditions met; offer is unconditional."
    },
    {
      "@id": "ion:CONDITIONALLY_APPROVED",
      "@type": "skos:Concept",
      "skos:prefLabel": "CONDITIONALLY_APPROVED",
      "skos:broader": {
        "@id": "ion:OfferStatus"
      },
      "rdfs:comment": "Offer approved subject to outstanding conditions in additionalConditions[]."
    },
    {
      "@id": "ion:REJECTED",
      "@type": "skos:Concept",
      "skos:prefLabel": "REJECTED",
      "skos:broader": {
        "@id": "ion:OfferStatus"
      },
      "rdfs:comment": "Credit application declined; SPPP letter required per POJK 6/2022."
    }
  ]
}