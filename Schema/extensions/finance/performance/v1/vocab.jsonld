{
  "@context": {
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ion": "https://schema.ion.id/finance/performance/v1#",
    "schema": "https://schema.org/"
  },
  "@graph": [
    {
      "@id": "ion:DisbursementPerformance",
      "rdf:type": "rdfs:Class",
      "rdfs:comment": "Loan disbursement execution record.",
      "rdfs:subClassOf": {
        "@id": "schema:PaymentMethod"
      }
    },
    {
      "@id": "ion:disbursementDate",
      "rdf:type": "rdf:Property",
      "rdfs:comment": "Date funds were actually disbursed."
    },
    {
      "@id": "ion:targetBusinessDays",
      "rdf:type": "rdf:Property",
      "rdfs:comment": "Target working days from document completion to disbursement."
    },
    {
      "@id": "ion:disbursementMethod",
      "rdf:type": "rdf:Property",
      "rdfs:comment": "Transfer mechanism: BANK_TRANSFER, DEVELOPER_TRANSFER, DEALER_TRANSFER, CASH, VIRTUAL_ACCOUNT."
    }
  ]
}
