{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.ion.id/finance/consideration/v1/schema.json",
  "title": "LoanConsideration",
  "description": "ION Finance Credit Consideration Extension v1 — principal and fee amounts placed in Consideration.considerationAttributes.",
  "type": "object",
  "required": [
    "@context",
    "@type",
    "approvedPrincipal",
    "currency"
  ],
  "additionalProperties": true,
  "properties": {
    "@context": {
      "type": "string",
      "const": "https://schema.ion.id/finance/consideration/v1/context.jsonld"
    },
    "@type": {
      "type": "string",
      "const": "ion:LoanConsideration"
    },
    "approvedPrincipal": {
      "type": "number"
    },
    "currency": {
      "type": "string",
      "default": "IDR"
    },
    "totalFeesIDR": {
      "type": "number"
    },
    "aprEquivalent": {
      "type": "number"
    }
  }
}
