{
  "@context": {
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "schema": "https://schema.org/",
    "ion": "https://schema.ion.id/finance/resource/v1#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#"
  },
  "@graph": [
    {
      "@id": "ion:CreditProduct",
      "@type": "rdfs:Class",
      "rdfs:subClassOf": {
        "@id": "schema:LoanOrCredit"
      },
      "rdfs:label": "CreditProduct",
      "rdfs:comment": "Product template for credit/financing offerings. Placed in Beckn Resource.resourceAttributes within Catalog.resources[] returned in on_discover. Carries ranges (not exact values) — exact per-applicant values are in CreditApproval."
    },
    {
      "@id": "ion:ProductIdentity",
      "@type": "rdfs:Class",
      "rdfs:label": "ProductIdentity",
      "rdfs:comment": "Product name, type, institution, and channel information. Block 1 of CreditProduct.",
      "rdfs:subClassOf": {
        "@id": "schema:FinancialProduct"
      }
    },
    {
      "@id": "ion:PrincipalRange",
      "@type": "rdfs:Class",
      "rdfs:label": "PrincipalRange",
      "rdfs:comment": "Min/max principal amount range offered. Block 2 of CreditProduct.",
      "rdfs:subClassOf": {
        "@id": "schema:MonetaryAmount"
      }
    },
    {
      "@id": "ion:MonetaryAmount",
      "@type": "rdfs:Class",
      "rdfs:label": "MonetaryAmount",
      "rdfs:comment": "A monetary value paired with its ISO 4217 currency code.",
      "rdfs:subClassOf": {
        "@id": "schema:MonetaryAmount"
      }
    },
    {
      "@id": "ion:Tenor",
      "@type": "rdfs:Class",
      "rdfs:label": "Tenor",
      "rdfs:comment": "Loan tenure range and available discrete options. Block 3 of CreditProduct.",
      "rdfs:subClassOf": {
        "@id": "schema:LoanOrCredit"
      }
    },
    {
      "@id": "ion:CostOfFundMechanism",
      "@type": "rdfs:Class",
      "rdfs:label": "CostOfFundMechanism",
      "rdfs:comment": "Interest or profit mechanics (conventional or Islamic). Block 4 of CreditProduct.",
      "rdfs:subClassOf": {
        "@id": "schema:LoanOrCredit"
      }
    },
    {
      "@id": "ion:RepaymentSchedule",
      "@type": "rdfs:Class",
      "rdfs:label": "RepaymentSchedule",
      "rdfs:comment": "Repayment frequency and accepted payment channels. Block 5 of CreditProduct.",
      "rdfs:subClassOf": {
        "@id": "schema:RepaymentSpecification"
      }
    },
    {
      "@id": "ion:FeeStructure",
      "@type": "rdfs:Class",
      "rdfs:label": "FeeStructure",
      "rdfs:comment": "All fees and charges for this product. Block 6 of CreditProduct.",
      "rdfs:subClassOf": {
        "@id": "schema:PriceSpecification"
      }
    },
    {
      "@id": "ion:Collateral",
      "@type": "rdfs:Class",
      "rdfs:label": "Collateral",
      "rdfs:comment": "Collateral types, LTV limits, and guarantee institutions. Block 7 of CreditProduct.",
      "rdfs:subClassOf": {
        "@id": "schema:LoanOrCredit"
      }
    },
    {
      "@id": "ion:BorrowerCriteria",
      "@type": "rdfs:Class",
      "rdfs:label": "BorrowerCriteria",
      "rdfs:comment": "Borrower eligibility requirements. Block 8 of CreditProduct.",
      "rdfs:subClassOf": {
        "@id": "schema:LoanOrCredit"
      }
    },
    {
      "@id": "ion:RegulatoryDeclaration",
      "@type": "rdfs:Class",
      "rdfs:label": "RegulatoryDeclaration",
      "rdfs:comment": "OJK/BI licenses, disclosures, and complaint service. Block 9 of CreditProduct.",
      "rdfs:subClassOf": {
        "@id": "schema:FinancialService"
      }
    },
    {
      "@id": "ion:License",
      "@type": "rdfs:Class",
      "rdfs:label": "License",
      "rdfs:comment": "Single OJK/BI/DSN-MUI license record within RegulatoryDeclaration.",
      "rdfs:subClassOf": {
        "@id": "schema:FinancialService"
      }
    },
    {
      "@id": "ion:Disclosure",
      "@type": "rdfs:Class",
      "rdfs:label": "Disclosure",
      "rdfs:comment": "Required consumer disclosure document reference (RIPLAY, T&C, privacy policy, etc.).",
      "rdfs:subClassOf": {
        "@id": "schema:DigitalDocument"
      }
    },
    {
      "@id": "ion:ComplaintService",
      "@type": "rdfs:Class",
      "rdfs:label": "ComplaintService",
      "rdfs:comment": "Complaint and grievance redressal contacts per POJK 6/POJK.07/2022.",
      "rdfs:subClassOf": {
        "@id": "schema:ContactPoint"
      }
    },
    {
      "@id": "ion:RequiredDocument",
      "@type": "rdfs:Class",
      "rdfs:label": "RequiredDocument",
      "rdfs:comment": "A single document required from the borrower. Block 10 of CreditProduct.",
      "rdfs:subClassOf": {
        "@id": "schema:DigitalDocument"
      }
    },
    {
      "@id": "ion:IslamicFinanceStructure",
      "@type": "rdfs:Class",
      "rdfs:label": "IslamicFinanceStructure",
      "rdfs:comment": "Islamic contract (akad) details and DSN-MUI fatwa reference. Block 11 — present only when financeType=ISLAMIC.",
      "rdfs:subClassOf": {
        "@id": "schema:LoanOrCredit"
      }
    },
    {
      "@id": "ion:GovernmentProgram",
      "@type": "rdfs:Class",
      "rdfs:label": "GovernmentProgram",
      "rdfs:comment": "Government subsidy program details (KUR, FLPP, UMi, BPUM). Block 12 — present for subsidised products.",
      "rdfs:subClassOf": {
        "@id": "schema:GovernmentService"
      }
    },
    {
      "@id": "ion:PaylaterService",
      "@type": "rdfs:Class",
      "rdfs:label": "PaylaterService",
      "rdfs:comment": "BNPL / Paylater specific attributes. Block 13 — present only for productType=PAYLATER.",
      "rdfs:subClassOf": {
        "@id": "schema:PaymentService"
      }
    },
    {
      "@id": "ion:productIdentity",
      "@type": "rdf:Property",
      "rdfs:label": "productIdentity",
      "rdfs:range": {
        "@id": "ion:ProductIdentity"
      },
      "rdfs:comment": "Product name, type, institution, and distribution channel information."
    },
    {
      "@id": "ion:principalRange",
      "@type": "rdf:Property",
      "rdfs:label": "principalRange",
      "rdfs:range": {
        "@id": "ion:PrincipalRange"
      },
      "rdfs:comment": "Min/max principal amount offered by this credit product."
    },
    {
      "@id": "ion:tenor",
      "@type": "rdf:Property",
      "rdfs:label": "tenor",
      "rdfs:range": {
        "@id": "ion:Tenor"
      },
      "rdfs:comment": "Loan tenure range (minimum, maximum, available options)."
    },
    {
      "@id": "ion:costOfFund",
      "@type": "rdf:Property",
      "rdfs:label": "costOfFund",
      "rdfs:range": {
        "@id": "ion:CostOfFundMechanism"
      },
      "rdfs:comment": "Interest or profit mechanics and rate range."
    },
    {
      "@id": "ion:repaymentSchedule",
      "@type": "rdf:Property",
      "rdfs:label": "repaymentSchedule",
      "rdfs:range": {
        "@id": "ion:RepaymentSchedule"
      },
      "rdfs:comment": "Repayment schedule, frequency, and accepted payment channels."
    },
    {
      "@id": "ion:feeStructure",
      "@type": "rdf:Property",
      "rdfs:label": "feeStructure",
      "rdfs:range": {
        "@id": "ion:FeeStructure"
      },
      "rdfs:comment": "All fees and charges associated with this credit product."
    },
    {
      "@id": "ion:collateral",
      "@type": "rdf:Property",
      "rdfs:label": "collateral",
      "rdfs:range": {
        "@id": "ion:Collateral"
      },
      "rdfs:comment": "Collateral types, LTV limits, and guarantee institution."
    },
    {
      "@id": "ion:borrowerCriteria",
      "@type": "rdf:Property",
      "rdfs:label": "borrowerCriteria",
      "rdfs:range": {
        "@id": "ion:BorrowerCriteria"
      },
      "rdfs:comment": "Borrower eligibility and qualification criteria."
    },
    {
      "@id": "ion:regulatoryDeclaration",
      "@type": "rdf:Property",
      "rdfs:label": "regulatoryDeclaration",
      "rdfs:range": {
        "@id": "ion:RegulatoryDeclaration"
      },
      "rdfs:comment": "Regulatory licenses, consumer disclosures, and complaint channel."
    },
    {
      "@id": "ion:requiredDocuments",
      "@type": "rdf:Property",
      "rdfs:label": "requiredDocuments",
      "rdfs:range": {
        "@id": "ion:RequiredDocument"
      },
      "rdfs:comment": "Checklist of documents required from the borrower."
    },
    {
      "@id": "ion:islamicFinance",
      "@type": "rdf:Property",
      "rdfs:label": "islamicFinance",
      "rdfs:range": {
        "@id": "ion:IslamicFinanceStructure"
      },
      "rdfs:comment": "Islamic akad details. Present only when financeType=ISLAMIC."
    },
    {
      "@id": "ion:governmentProgram",
      "@type": "rdf:Property",
      "rdfs:label": "governmentProgram",
      "rdfs:range": {
        "@id": "ion:GovernmentProgram"
      },
      "rdfs:comment": "Government program details (KUR, FLPP, UMi, BPUM)."
    },
    {
      "@id": "ion:paylaterService",
      "@type": "rdf:Property",
      "rdfs:label": "paylaterService",
      "rdfs:range": {
        "@id": "ion:PaylaterService"
      },
      "rdfs:comment": "BNPL/Paylater attributes. Present only for productType=PAYLATER."
    },
    {
      "@id": "ion:productName",
      "@type": "rdf:Property",
      "rdfs:label": "productName",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "Official product name as in OJK registration and RIPLAY header."
    },
    {
      "@id": "ion:institutionName",
      "@type": "rdf:Property",
      "rdfs:label": "institutionName",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "Full legal entity name of the lending institution as registered with OJK."
    },
    {
      "@id": "ion:productType",
      "@type": "rdf:Property",
      "rdfs:label": "productType",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "Credit product category (KPR, KTA, KUR_MIKRO, PAYLATER, etc.)."
    },
    {
      "@id": "ion:financeType",
      "@type": "rdf:Property",
      "rdfs:label": "financeType",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "CONVENTIONAL (interest-based) or ISLAMIC (akad/DSN-MUI certified)."
    },
    {
      "@id": "ion:currency",
      "@type": "rdf:Property",
      "rdfs:label": "currency",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "ISO 4217 currency code for all monetary amounts (default IDR)."
    },
    {
      "@id": "ion:institutionType",
      "@type": "rdf:Property",
      "rdfs:label": "institutionType",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "OJK institution type (BANK_UMUM, BPR, BPRS, P2P_LENDING, etc.)."
    },
    {
      "@id": "ion:bankCapitalTier",
      "@type": "rdf:Property",
      "rdfs:label": "bankCapitalTier",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "BI BUKU capital tier (BUKU_1 to BUKU_4). Applies to BANK_UMUM only."
    },
    {
      "@id": "ion:digitalOnly",
      "@type": "rdf:Property",
      "rdfs:label": "digitalOnly",
      "rdfs:range": {
        "@id": "xsd:boolean"
      },
      "rdfs:comment": "True if no physical branch visit required for this product."
    },
    {
      "@id": "ion:distributionChannels",
      "@type": "rdf:Property",
      "rdfs:label": "distributionChannels",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "Available application channels (BRANCH_OFFICE, MOBILE_BANKING, etc.)."
    },
    {
      "@id": "ion:value",
      "@type": "rdf:Property",
      "rdfs:label": "value",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Numeric monetary amount in the currency specified by ion:currency."
    },
    {
      "@id": "ion:minimum",
      "@type": "rdf:Property",
      "rdfs:label": "minimum",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Minimum value for a range (principal or tenor)."
    },
    {
      "@id": "ion:maximum",
      "@type": "rdf:Property",
      "rdfs:label": "maximum",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Maximum value for a range (principal or tenor)."
    },
    {
      "@id": "ion:maximumKUROfficial",
      "@type": "rdf:Property",
      "rdfs:label": "maximumKUROfficial",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Official KUR plafond cap per government regulation (Permenko 1/2023)."
    },
    {
      "@id": "ion:denomination",
      "@type": "rdf:Property",
      "rdfs:label": "denomination",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Allowed principal increment (amount must be a multiple of this value)."
    },
    {
      "@id": "ion:unit",
      "@type": "rdf:Property",
      "rdfs:label": "unit",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "Time unit for tenor values (DAYS, MONTHS, or YEARS)."
    },
    {
      "@id": "ion:availableTenors",
      "@type": "rdf:Property",
      "rdfs:label": "availableTenors",
      "rdfs:range": {
        "@id": "xsd:integer"
      },
      "rdfs:comment": "Discrete list of available tenors when free selection is not permitted."
    },
    {
      "@id": "ion:yieldType",
      "@type": "rdf:Property",
      "rdfs:label": "yieldType",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "Cost-of-fund type (FIXED, FLOATING, COMBINED, MARGIN, NISBAH, UJRAH, ZERO_COST)."
    },
    {
      "@id": "ion:calculationMethod",
      "@type": "rdf:Property",
      "rdfs:label": "calculationMethod",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "Amortisation method (ANNUITY, FLAT, EFFECTIVE, DECLINING_BALANCE)."
    },
    {
      "@id": "ion:rateMinPercent",
      "@type": "rdf:Property",
      "rdfs:label": "rateMinPercent",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Minimum annual interest/margin rate offered for this product (%)."
    },
    {
      "@id": "ion:rateMaxPercent",
      "@type": "rdf:Property",
      "rdfs:label": "rateMaxPercent",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Maximum annual interest/margin rate offered for this product (%)."
    },
    {
      "@id": "ion:rateReference",
      "@type": "rdf:Property",
      "rdfs:label": "rateReference",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "Floating-rate benchmark (BI_RATE, SBDK, JIBOR, PRIME_RATE, SOFR)."
    },
    {
      "@id": "ion:spreadPercent",
      "@type": "rdf:Property",
      "rdfs:label": "spreadPercent",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Spread above benchmark rate for floating-rate products (% p.a.)."
    },
    {
      "@id": "ion:fixedPeriodYears",
      "@type": "rdf:Property",
      "rdfs:label": "fixedPeriodYears",
      "rdfs:range": {
        "@id": "xsd:integer"
      },
      "rdfs:comment": "Fixed-rate period in years for COMBINED products before switching to floating."
    },
    {
      "@id": "ion:governmentSubsidyPercent",
      "@type": "rdf:Property",
      "rdfs:label": "governmentSubsidyPercent",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Government interest subsidy rate (% p.a.) paid to the bank on KUR programs."
    },
    {
      "@id": "ion:effectiveRatePercent",
      "@type": "rdf:Property",
      "rdfs:label": "effectiveRatePercent",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Effective rate paid by the borrower after government subsidy deduction."
    },
    {
      "@id": "ion:frequency",
      "@type": "rdf:Property",
      "rdfs:label": "frequency",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "Repayment frequency (MONTHLY, QUARTERLY, BULLET, SEASONAL, etc.)."
    },
    {
      "@id": "ion:paymentChannels",
      "@type": "rdf:Property",
      "rdfs:label": "paymentChannels",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "Accepted payment channels (AUTODEBIT, QRIS, BIFAST, VIRTUAL_ACCOUNT, etc.)."
    },
    {
      "@id": "ion:gracePeriodDays",
      "@type": "rdf:Property",
      "rdfs:label": "gracePeriodDays",
      "rdfs:range": {
        "@id": "xsd:integer"
      },
      "rdfs:comment": "Number of days after due date before a late penalty applies."
    },
    {
      "@id": "ion:earlySettlementAllowed",
      "@type": "rdf:Property",
      "rdfs:label": "earlySettlementAllowed",
      "rdfs:range": {
        "@id": "xsd:boolean"
      },
      "rdfs:comment": "Whether partial or full early repayment is permitted."
    },
    {
      "@id": "ion:earlySettlementPenalty",
      "@type": "rdf:Property",
      "rdfs:label": "earlySettlementPenalty",
      "rdfs:range": {
        "@id": "xsd:boolean"
      },
      "rdfs:comment": "Whether early repayment incurs a penalty fee."
    },
    {
      "@id": "ion:restructuringAllowed",
      "@type": "rdf:Property",
      "rdfs:label": "restructuringAllowed",
      "rdfs:range": {
        "@id": "xsd:boolean"
      },
      "rdfs:comment": "Whether loan restructuring (moratorium, tenor extension) is available."
    },
    {
      "@id": "ion:provisionFeePercent",
      "@type": "rdf:Property",
      "rdfs:label": "provisionFeePercent",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Provision/origination fee as % of approved principal (paid upfront)."
    },
    {
      "@id": "ion:administrationFeeIDR",
      "@type": "rdf:Property",
      "rdfs:label": "administrationFeeIDR",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Flat administration fee for processing the credit application (IDR)."
    },
    {
      "@id": "ion:appraisalFeeIDR",
      "@type": "rdf:Property",
      "rdfs:label": "appraisalFeeIDR",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "KJPP collateral appraisal fee (IDR). Required for KPR, KKB, secured business credit."
    },
    {
      "@id": "ion:notaryFeeIDR",
      "@type": "rdf:Property",
      "rdfs:label": "notaryFeeIDR",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Estimated notary/PPAT fee for deed preparation (IDR)."
    },
    {
      "@id": "ion:stampDutyIDR",
      "@type": "rdf:Property",
      "rdfs:label": "stampDutyIDR",
      "rdfs:range": {
        "@id": "xsd:integer"
      },
      "rdfs:comment": "Stamp duty per document (e-Meterai IDR 10,000 per UU No. 10/2020)."
    },
    {
      "@id": "ion:required",
      "@type": "rdf:Property",
      "rdfs:label": "required",
      "rdfs:range": {
        "@id": "xsd:boolean"
      },
      "rdfs:comment": "Whether collateral is required for this credit product."
    },
    {
      "@id": "ion:collateralTypes",
      "@type": "rdf:Property",
      "rdfs:label": "collateralTypes",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "Accepted collateral types (PROPERTY, MOTOR_VEHICLE_CAR, GOLD, UNSECURED, etc.)."
    },
    {
      "@id": "ion:maxLTVPercent",
      "@type": "rdf:Property",
      "rdfs:label": "maxLTVPercent",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Maximum Loan-to-Value ratio (%) per BI regulation PBI 20/8/PBI/2018."
    },
    {
      "@id": "ion:appraisalRequired",
      "@type": "rdf:Property",
      "rdfs:label": "appraisalRequired",
      "rdfs:range": {
        "@id": "xsd:boolean"
      },
      "rdfs:comment": "Whether independent KJPP appraisal is required for this product."
    },
    {
      "@id": "ion:guarantorInstitution",
      "@type": "rdf:Property",
      "rdfs:label": "guarantorInstitution",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "Designated credit guarantee institution (JAMKRINDO, ASKRINDO, JAMKRIDA)."
    },
    {
      "@id": "ion:applicantTypes",
      "@type": "rdf:Property",
      "rdfs:label": "applicantTypes",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "rdfs:comment": "Eligible borrower entity types (INDIVIDUAL, MICRO_ENTERPRISE, CORPORATION, etc.)."
    },
    {
      "@id": "ion:minimumAge",
      "@type": "rdf:Property",
      "rdfs:label": "minimumAge",
      "rdfs:range": {
        "@id": "xsd:integer"
      },
      "rdfs:comment": "Minimum applicant age at time of application (years)."
    },
    {
      "@id": "ion:maximumAgeAtMaturity",
      "@type": "rdf:Property",
      "rdfs:label": "maximumAgeAtMaturity",
      "rdfs:range": {
        "@id": "xsd:integer"
      },
      "rdfs:comment": "Maximum borrower age at loan maturity (years)."
    },
    {
      "@id": "ion:minimumMonthlyIncomeIDR",
      "@type": "rdf:Property",
      "rdfs:label": "minimumMonthlyIncomeIDR",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "rdfs:comment": "Minimum gross monthly income required to qualify (IDR)."
    },
    {
      "@id": "ion:employmentTypes",
      "@type": "rdf:Property",
      "rdfs:label": "employmentTypes",
      "rdfs:range": {
        "@id": "xsd:string"
      },
