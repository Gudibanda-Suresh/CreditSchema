      "skos:prefLabel": "UJRAH",
      "skos:broader": {
        "@id": "ion:YieldType"
      },
      "rdfs:comment": "Islamic service fee / rental (Ijarah akad)."
    },
    {
      "@id": "ion:ZERO_COST",
      "@type": "skos:Concept",
      "skos:prefLabel": "ZERO_COST",
      "skos:broader": {
        "@id": "ion:YieldType"
      },
      "rdfs:comment": "Zero-cost financing (Qardh Hasan or fully-subsidised government programs)."
    },
    {
      "@id": "ion:ANNUITY",
      "@type": "skos:Concept",
      "skos:prefLabel": "ANNUITY",
      "skos:broader": {
        "@id": "ion:CalculationMethod"
      },
      "rdfs:comment": "Equal total installment each period; principal component rises, interest falls."
    },
    {
      "@id": "ion:FLAT",
      "@type": "skos:Concept",
      "skos:prefLabel": "FLAT",
      "skos:broader": {
        "@id": "ion:CalculationMethod"
      },
      "rdfs:comment": "Interest calculated on original principal; equal installments throughout."
    },
    {
      "@id": "ion:EFFECTIVE",
      "@type": "skos:Concept",
      "skos:prefLabel": "EFFECTIVE",
      "skos:broader": {
        "@id": "ion:CalculationMethod"
      },
      "rdfs:comment": "Interest calculated on outstanding balance; equivalent to declining-balance."
