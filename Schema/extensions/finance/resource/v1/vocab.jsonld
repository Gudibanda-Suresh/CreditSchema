        "rdfs:Class",
        "skos:ConceptScheme"
      ],
      "rdfs:label": "InstitutionType",
      "rdfs:comment": "OJK-defined taxonomy of licensed financial institution categories in Indonesia."
    },
    {
      "@id": "ion:ProductTypeScheme",
      "@type": [
        "rdfs:Class",
        "skos:ConceptScheme"
      ],
      "rdfs:label": "ProductTypeScheme",
      "rdfs:comment": "Taxonomy of credit product categories recognised on the ION network."
    },
    {
      "@id": "ion:FIXED",
      "@type": "skos:Concept",
      "skos:prefLabel": "FIXED",
      "skos:broader": {
        "@id": "ion:YieldType"
      },
      "rdfs:comment": "Fixed interest rate throughout the entire loan tenor."
    },
    {
      "@id": "ion:FLOATING",
      "@type": "skos:Concept",
      "skos:prefLabel": "FLOATING",
      "skos:broader": {
        "@id": "ion:YieldType"
      },
      "rdfs:comment": "Floating rate tied to a reference index (BI Rate, SBDK, JIBOR)."
    },
    {
      "@id": "ion:COMBINED",
      "@type": "skos:Concept",
      "skos:prefLabel": "COMBINED",
      "skos:broader": {
        "@id": "ion:YieldType"
      },
      "rdfs:comment": "Fixed rate for an initial period then switches to floating."
    },
    {
      "@id": "ion:MARGIN",
      "@type": "skos:Concept",
      "skos:prefLabel": "MARGIN",
      "skos:broader": {
        "@id": "ion:YieldType"
      },
      "rdfs:comment": "Islamic fixed margin (Murabahah / Istishna akad)."
    },
    {
      "@id": "ion:NISBAH",
      "@type": "skos:Concept",
      "skos:prefLabel": "NISBAH",
      "skos:broader": {
        "@id": "ion:YieldType"
      },
      "rdfs:comment": "Islamic profit-sharing ratio (Mudharabah / Musharakah akad)."
    },
